// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "dependsOn": ["vp: typecheck", "vp: build"],
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "shell",
      "command": "vp build --watch",
      "group": "build",
      "problemMatcher": [],
      "isBackground": true,
      "label": "vp: build",
      "presentation": {
        "group": "watch",
        "reveal": "never"
      }
    },
    {
      "type": "shell",
      "command": "vp exec tsc --watch --noEmit",
      "group": "build",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "label": "vp: typecheck",
      "presentation": {
        "group": "watch",
        "reveal": "never"
      }
    }
  ]
}
